# Resend: API key for sending contact form emails to info@anklagroupinc.com
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Requerido para enviar a info@anklagroupinc.com: verifica tu dominio en resend.com/domains
# y usa un email de ese dominio como remitente (ej: contacto@anklagroupinc.com).
# Sin esto, Resend solo permite enviar al email de tu cuenta (modo prueba).
RESEND_FROM_EMAIL=contacto@anklagroupinc.com
