# Resend: API key for sending contact form emails to contactus@anklagroupinc.com (+ test copy)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Requerido para enviar a contactus@anklagroupinc.com: verifica tu dominio en resend.com/domains
# y usa un email de ese dominio como remitente (ej: contactus@anklagroupinc.com).
# Sin esto, Resend solo permite enviar al email de tu cuenta (modo prueba).
RESEND_FROM_EMAIL=contactus@anklagroupinc.com
